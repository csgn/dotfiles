{
	"layer": "top",
	"position": "bottom",
	"height": 48,
	"modules-left": [
		"hyprland/workspaces"
		//"tray"
	],
	"modules-center": [
		"hyprland/window"
	],
	"modules-right": [
		"cpu",
		"memory",
		"power-profiles-daemon",
		"custom/language",
		"idle_inhibitor",
		"bluetooth",
		"battery",
		"pulseaudio",
		"network",
		"clock"
	],
	"group/hardware": {
		"orientation": "vertical",
		"modules": [
			"cpu",
			"memory",
			"battery"
		]
	},
	"hyprland/workspaces": {
		"disable-scroll": true,
		"all-outputs": true
	},
	"hyprland/window": {
		"format": "{class} | ",
		"separate-outputs": true,
		"tooltip-format": "{title}"
	},
	"bluetooth": {
